# RedIntel Sentinel - environment configuration example.
# Copy to .env for local development. All variables are prefixed with REDINTEL_
# and use underscores in place of the dotted config path
# (e.g. server.port -> REDINTEL_SERVER_PORT).

# Application
REDINTEL_APP_NAME=redintel-sentinel
REDINTEL_APP_ENVIRONMENT=development

# HTTP server
REDINTEL_SERVER_HOST=0.0.0.0
REDINTEL_SERVER_PORT=8080
REDINTEL_SERVER_SHUTDOWN_TIMEOUT=15s

# PostgreSQL
REDINTEL_DATABASE_HOST=localhost
REDINTEL_DATABASE_PORT=5432
REDINTEL_DATABASE_USER=postgres
REDINTEL_DATABASE_PASSWORD=postgres
REDINTEL_DATABASE_NAME=redintel
REDINTEL_DATABASE_SSLMODE=disable

# Redis
REDINTEL_REDIS_HOST=localhost
REDINTEL_REDIS_PORT=6379
REDINTEL_REDIS_PASSWORD=
REDINTEL_REDIS_DB=0

# Logging
REDINTEL_LOG_LEVEL=info
REDINTEL_LOG_FORMAT=json
